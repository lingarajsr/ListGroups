<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bootstrap Typography Example</title>

    <!-- Bootstrap 4 CSS CDN -->
    <link rel="stylesheet"
    href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
</head>

<body>

<div class="container mt-5">
    
    <div class="row">
        <div class="col-md-12">
            
            <!-- Display Heading -->
            <h1 class="display-1 text-center">
                Bootstrap Typography
            </h1>

            <!-- Left Aligned Paragraph -->
            <p class="text-left">
                This is the first paragraph aligned to the left using Bootstrap 
                text alignment utility classes. Bootstrap provides simple classes 
                to control text positioning.
            </p>

            <!-- Right Aligned Paragraph -->
            <p class="text-right">
                This is the second paragraph aligned to the right using Bootstrap 
                typography utilities. These classes help in creating responsive 
                and well-structured layouts easily.
            </p>

        </div>
    </div>

</div>

<!-- Bootstrap 4 JS -->
<script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
