<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bootstrap Grid Example</title>

    <!-- Bootstrap 4 CSS CDN -->
    <link rel="stylesheet"
    href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
</head>

<body>

<div class="container mt-5">
    
    <div class="row align-items-center">
        
        <!-- Column 1: Text -->
        <div class="col-md-6">
            <h2>Welcome to Bootstrap Grid</h2>
            <p>
                This column contains text content. The Bootstrap grid system 
                divides the layout into 12 columns. Here we are using 
                col-md-6, which means the column takes 6 out of 12 columns 
                on medium and larger screens.
            </p>
        </div>

        <!-- Column 2: Online Image -->
        <div class="col-md-6 text-center">
            <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c"
                 class="img-fluid rounded"
                 alt="Bootstrap Example Image">
        </div>

    </div>

</div>

<!-- Bootstrap 4 JS -->
<script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
