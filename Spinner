<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bootstrap Spinners Task</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
</head>
<body>

    <div class="container mt-5">
        
        <div class="row">
            <div class="col-md-12">
                <h2 class="mb-4">Bootstrap Spinner Utilities</h2>

                <section class="mb-5">
                    <h5>Basic Spinner (Border)</h5>
                    <div class="spinner-border" role="status">
                        <span class="sr-only">Loading...</span>
                    </div>
                </section>

                <section class="mb-5">
                    <h5>Growing Spinner</h5>
                    <div class="spinner-grow" role="status">
                        <span class="sr-only">Loading...</span>
                    </div>
                </section>

                <section class="mb-5">
                    <h5>Color Spinners</h5>
                    <div class="spinner-border text-primary" role="status"></div>
                    <div class="spinner-border text-success" role="status"></div>
                    <div class="spinner-border text-danger" role="status"></div>
                    <div class="spinner-border text-warning" role="status"></div>
                    
                    <div class="mt-3">
                        <div class="spinner-grow text-info" role="status"></div>
                        <div class="spinner-grow text-light" role="status"></div>
                        <div class="spinner-grow text-dark" role="status"></div>
                    </div>
                </section>

                <section class="mb-5">
                    <h5>Spinners within Buttons</h5>
                    <button class="btn btn-primary" type="button" disabled>
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        Loading...
                    </button>
                    
                    <button class="btn btn-success ml-2" type="button" disabled>
                        <span class="spinner-grow spinner-grow-sm" role="status" aria-hidden="true"></span>
                        Processing...
                    </button>
                </section>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.5.1/dist/jquery.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
