<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bootstrap Pagination Task</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
</head>
<body>

    <div class="container mt-5">
        
        <div class="row">
            <div class="col-md-12">
                <h2 class="mb-4">Bootstrap Pagination Utilities</h2>

                <p>This demonstration shows basic pagination including active and disabled states.</p>

                <nav aria-label="Page navigation example">
                  <ul class="pagination">
                    <li class="page-item disabled">
                      <a class="page-item page-link" href="#" tabindex="-1" aria-disabled="true">Previous</a>
                    </li>
                    
                    <li class="page-item"><a class="page-link" href="#">1</a></li>
                    
                    <li class="page-item active" aria-current="page">
                      <a class="page-link" href="#">2 <span class="sr-only">(current)</span></a>
                    </li>
                    
                    <li class="page-item"><a class="page-link" href="#">3</a></li>
                    
                    <li class="page-item">
                      <a class="page-link" href="#">Next</a>
                    </li>
                  </ul>
                </nav>

                <div class="mt-5 p-3 bg-light border rounded">
                    <h6>Code Explained:</h6>
                    <ul>
                        <li><code>.pagination</code>: The wrapper for the list items.</li>
                        <li><code>.page-item</code>: Applied to the <code>&lt;li&gt;</code> elements.</li>
                        <li><code>.active</code>: Highlights the current page (Blue background).</li>
                        <li><code>.disabled</code>: Grays out the link and makes it unclickable.</li>
                    </ul>
                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.5.1/dist/jquery.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
