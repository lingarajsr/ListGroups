<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bootstrap Image Styling Task</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
</head>
<body>

    <div class="container mt-5">
        
        <div class="row">
            <div class="col-md-12 text-center">
                <h2 class="mb-4">Bootstrap Image Utility Demonstration</h2>

                <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1200&q=80" 
                     class="img-fluid rounded img-thumbnail" 
                     alt="Modern Office Space"
                     style="max-height: 500px; width: 100%; object-fit: cover;">
                
                <div class="mt-4 p-3 bg-light border">
                    <h5>Applied Classes:</h5>
                    <ul class="list-inline">
                        <li class="list-inline-item badge badge-primary">.img-fluid</li>
                        <li class="list-inline-item badge badge-secondary">.rounded</li>
                        <li class="list-inline-item badge badge-info">.img-thumbnail</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.5.1/dist/jquery.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
