<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bootstrap 4 Flexbox Layout</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <style>
        .flex-box {
            min-height: 150px;
            background-color: #e9ecef;
            border: 2px dashed #6c757d;
            margin-bottom: 30px;
        }
        .item {
            padding: 20px;
            background-color: #007bff;
            color: white;
            border: 1px solid white;
            border-radius: 5px;
        }
    </style>
</head>
<body>

<div class="container mt-5">
    <h2 class="text-center mb-5">Bootstrap 4 Flexbox Utilities</h2>

    <h4>Justify Content (Spacing)</h4>
    <div class="d-flex justify-content-around align-items-center flex-box">
        <div class="item">Item 1</div>
        <div class="item">Item 2</div>
        <div class="item">Item 3</div>
    </div>

    <h4>Align Items (Vertical Alignment)</h4>
    <div class="d-flex align-items-end flex-box">
        <div class="item">Aligned to Bottom</div>
        <div class="item" style="height: 100px;">Taller Item</div>
    </div>

    <h4>Flex Wrap & Ordering</h4>
    <div class="d-flex flex-wrap flex-box">
        <div class="item order-3 m-2">Box A (Order 3)</div>
        <div class="item order-1 m-2">Box B (Order 1)</div>
        <div class="item order-2 m-2">Box C (Order 2)</div>
        <div class="item m-2">Box D (Default)</div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
